    "@grpc/grpc-js": "^1.10.6",
    "@grpc/proto-loader": "^0.7.12",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^11.1.18",
    "@nestjs/microservices": "^10.3.8",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/terminus": "^10.2.3",
    "@pariksha/shared": "*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
